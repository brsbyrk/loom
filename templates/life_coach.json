        {"attribute": "wealth.cash", "delta": -30000.0},
        {"attribute": "health.stress", "delta": 25.0}
      ],
      "spawns_decision_id": "job_search_options"
    },
    {
      "id": "burnout",
      "label": "Burnout",
      "description": "Chronic stress leads to burnout — you can't function at full capacity",
      "preconditions": [
        {"attribute": "health.stress", "operator": "Gt", "value": 75.0}
      ],
      "delay": 2,
      "duration": 3,
      "cooldown": 30,
      "priority": 5,
      "effects": [
        {"attribute": "health.physical", "delta": -4.0},
        {"attribute": "health.stress", "delta": 3.0}
      ],
      "triggers_event_id": "depression_risk"
    },
    {
      "id": "depression_risk",
      "label": "Risk of depression",
      "description": "Your mental health is deteriorating — either triggered by burnout or when physical health drops too low",
      "precondition_mode": "any",
      "preconditions": [
        {"attribute": "health.physical", "operator": "Lt", "value": 40.0}
      ],
      "triggered_by": ["burnout"],
      "suppressed_by": ["therapy_session"],
      "priority": 10,
      "delay": 1,
      "duration": 2,
      "cooldown": 48,
      "effects": [
        {"attribute": "health.stress", "delta": 10.0},
        {"attribute": "social.alice", "delta": -5.0},
        {"attribute": "social.bob", "delta": -5.0}
      ],
      "triggers_event_id": "social_isolation"
    },
    {
      "id": "social_isolation",
      "label": "Social isolation",
      "description": "You withdraw from your social circles — friends notice your absence",
      "triggered_by": ["depression_risk"],
      "priority": 8,
      "delay": 0,
      "duration": 3,
      "cooldown": 60,
      "effects": [
        {"attribute": "social.alice", "delta": -10.0},
        {"attribute": "social.bob", "delta": -15.0},
        {"attribute": "skills.negotiation", "delta": -3.0}
      ],
      "triggers_on_resolve": "therapy_session"
    },
    {
      "id": "therapy_session",
      "label": "Therapy session opportunity",
      "description": "After a period of isolation, you seek professional help",
      "triggered_by": ["social_isolation"],
      "delay": 0,
      "duration": 1,
      "cooldown": 24,
      "effects": [
        {"attribute": "health.stress", "delta": -20.0},
        {"attribute": "health.physical", "delta": 5.0},
        {"attribute": "wealth.cash", "delta": -1500.0}
      ],
