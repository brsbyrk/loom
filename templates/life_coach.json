      "duration": 1,
      "cooldown": 30,
      "effects": [
        {"attribute": "wealth.cash", "delta": -2000.0}
      ]
    },
    {
      "id": "health_scare",
      "label": "Health scare",
      "description": "Your body is giving you warning signs",
