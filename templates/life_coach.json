        "operator": "Gt",
        "value": 70
      },
      "effects": [
        {"attribute": "health.physical", "delta": -0.5}
      ]
    },
    {
      "id": "living_expenses",
      "label": "Living expenses (all wealth groups)",
      "frequency": {"type": "everystep"},
      "effects": [
        {"group": "wealth", "delta": -250}
      ]
    }
  ],
  "goals": {
