        {"attribute": "health.physical", "operator": "Lt", "value": 40.0}
      ],
      "delay": 1,
      "duration": 1,
      "cooldown": 24,
      "effects": [
        {"attribute": "health.physical", "delta": -8.0},
        {"attribute": "health.stress", "delta": 15.0}
