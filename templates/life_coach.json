        {"attribute": "social.alice", "delta": -10.0},
        {"attribute": "social.bob", "delta": -10.0},
        {"attribute": "health.stress", "delta": 5.0}
      ]
    },
    {
      "id": "layoff_wave",
      "label": "Layoff wave hits your company",
      "description": "Your company announces mass layoffs",
      "preconditions": [
        {"attribute": "skills.rust", "operator": "Lt", "value": 50.0}
      ],
      "delay": 3,
      "duration": 1,
      "cooldown": 48,
